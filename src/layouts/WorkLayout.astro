---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Lightbox from '../components/Lightbox.astro';

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const data = entry.data;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const workHref = `${base}/work`;
---

<BaseLayout title={`${data.title} · Work`} description={data.tagline}>
  <div class="wrap">
    <a class="back-link" href={workHref}>← All work</a>

    <header class="work-hero">
      <div class="work-theme">{data.theme}</div>
      <h1 class="work-title">{data.title}</h1>
      <p class="work-tagline">{data.tagline}</p>
      {
        data.stack.length > 0 && (
          <div class="stack">
            {data.stack.map((s) => (
              <span class="pill">{s}</span>
            ))}
          </div>
        )
      }
    </header>

    <article class="work-body">
      <slot />
    </article>

    <footer>
      <span>Work · {data.title}</span>
      <span>End of file</span>
    </footer>
  </div>
  <Lightbox />
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin: 32px 0 0;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-dim);
    text-decoration: none;
    transition: color 0.18s ease;
  }
  .back-link:hover,
  .back-link:focus-visible {
    color: var(--amber);
    outline: none;
  }

  .work-hero {
    padding: 40px 0 50px;
    border-bottom: 1px solid var(--rule);
  }
  .work-theme {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 22px;
  }
  .work-title {
    font-family: var(--serif);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 18px;
  }
  .work-tagline {
    font-size: clamp(15px, 1.6vw, 18px);
    line-height: 1.6;
    color: var(--ink-dim);
    max-width: 60ch;
    font-weight: 300;
  }
  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 26px;
  }
  .pill {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-dim);
    border: 1px solid var(--rule);
    padding: 5px 10px;
  }

  .work-body {
    padding: 50px 0 70px;
  }

  /* MDX prose styling — h2 sections get the amber section-label treatment */
  .work-body :global(h2) {
    font-family: var(--mono);
    font-weight: 400;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--amber);
    margin: 48px 0 18px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .work-body :global(h2)::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--rule);
  }
  .work-body :global(h2:first-child) {
    margin-top: 0;
  }
  .work-body :global(p) {
    font-size: 15.5px;
    line-height: 1.7;
    color: var(--ink-dim);
    max-width: 64ch;
    margin-bottom: 16px;
  }
  .work-body :global(p strong),
  .work-body :global(li strong) {
    color: var(--ink);
    font-weight: 500;
  }
  .work-body :global(ul) {
    list-style: none;
    margin: 0 0 16px;
    padding: 0;
    max-width: 64ch;
  }
  .work-body :global(ul li) {
    position: relative;
    padding: 10px 0 10px 22px;
    border-bottom: 1px solid var(--rule);
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink-dim);
  }
  .work-body :global(ul li:last-child) {
    border-bottom: 0;
  }
  .work-body :global(ul li)::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--teal);
    font-family: var(--mono);
  }
  .work-body :global(a) {
    color: var(--teal);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
  }
  .work-body :global(a:hover) {
    color: var(--amber);
  }
  .work-body :global(code) {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--teal);
    background: var(--bg-2);
    padding: 1px 6px;
    border: 1px solid var(--rule);
  }
</style>
