---
---

<dialog class="lightbox" id="lightbox">
  <button type="button" class="lightbox-close" aria-label="Close">✕ Esc</button>
  <img class="lightbox-img" alt="" />
</dialog>

<style>
  .lightbox {
    padding: 0;
    border: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    overflow: visible;
  }
  .lightbox::backdrop {
    background: rgba(8, 6, 5, 0.92);
    backdrop-filter: blur(4px);
  }
  .lightbox-img {
    display: block;
    max-width: 95vw;
    max-height: 95vh;
    object-fit: contain;
    cursor: zoom-out;
    border: 1px solid var(--rule);
  }
  .lightbox-close {
    position: fixed;
    top: 20px;
    right: 20px;
    background: rgba(12, 10, 9, 0.85);
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 8px 14px;
    cursor: pointer;
    backdrop-filter: blur(4px);
  }
  .lightbox-close:hover {
    color: var(--rose);
    border-color: var(--rose);
  }
</style>

<script>
  const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
  const imgEl = dialog?.querySelector<HTMLImageElement>('.lightbox-img') ?? null;
  const closeBtn = dialog?.querySelector<HTMLButtonElement>('.lightbox-close') ?? null;

  if (dialog && imgEl && closeBtn) {
    const open = (src: HTMLImageElement) => {
      imgEl.src = src.currentSrc || src.src;
      imgEl.alt = src.alt;
      dialog.showModal();
      document.body.style.overflow = 'hidden';
    };

    const close = () => {
      if (dialog.open) dialog.close();
      document.body.style.overflow = '';
      imgEl.removeAttribute('src');
    };

    document.addEventListener('click', (e) => {
      const trigger = (e.target as HTMLElement).closest<HTMLButtonElement>('.shot-trigger');
      if (!trigger) return;
      const img = trigger.querySelector('img');
      if (img) open(img);
    });

    closeBtn.addEventListener('click', close);
    imgEl.addEventListener('click', close);
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) close();
    });
    dialog.addEventListener('close', () => {
      document.body.style.overflow = '';
    });
  }
</script>
