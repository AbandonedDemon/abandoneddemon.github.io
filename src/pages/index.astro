---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// TODO(author): refine the intro copy.
const entries = [
  {
    kicker: 'Portfolio',
    title: 'Work',
    body: 'Tools I designed and built — grading pipelines, time-logging dashboards, browser extensions. Written up end to end.',
    href: `${base}/work`,
  },
  {
    kicker: 'Field Guides',
    title: 'GFX Guides',
    body: 'Long-form, opinionated walkthroughs of specific creative workflows. One recipe per guide, start to finish.',
    href: `${base}/gfx-guides`,
  },
];
---

<BaseLayout
  title="abdemon"
  description="Developer and GFX editor. Tooling, automation, and long-form edit guides."
>
  <div class="wrap">
    <header class="hero">
      <div class="eyebrow">abdemon · Home</div>
      <h1><em>abdemon</em></h1>
      <p class="lede">
        I build tools that take the friction out of repetitive work — and write up the GFX editing
        recipes I use myself. Two things live here.
      </p>
    </header>

    <section class="entries">
      {
        entries.map((e) => (
          <a class="entry-card" href={e.href}>
            <div class="entry-kicker">{e.kicker}</div>
            <div class="entry-title">{e.title}</div>
            <p class="entry-body">{e.body}</p>
            <span class="entry-arrow">→</span>
          </a>
        ))
      }
    </section>

    <footer>
      <span>abdemon</span>
      <span>End of file</span>
    </footer>
  </div>
</BaseLayout>

<style>
  .entries {
    padding: 60px 0 80px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--rule);
  }
  .entry-card {
    position: relative;
    background: var(--bg);
    padding: 36px 32px 44px;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 200ms;
  }
  .entry-card:hover {
    background: var(--bg-2);
  }
  .entry-kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--teal);
  }
  .entry-title {
    font-family: var(--serif);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(30px, 3.4vw, 42px);
    line-height: 1.05;
    color: var(--ink);
  }
  .entry-body {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink-dim);
    max-width: 42ch;
  }
  .entry-arrow {
    margin-top: auto;
    font-family: var(--mono);
    font-size: 18px;
    color: var(--ink-faint);
    transition: color 200ms;
  }
  .entry-card:hover .entry-arrow {
    color: var(--amber);
  }
  @media (max-width: 760px) {
    .entries {
      grid-template-columns: 1fr;
    }
  }
</style>
