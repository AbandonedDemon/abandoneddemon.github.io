---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = (await getCollection('works')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const workHref = (slug: string) => `${base}/works/${slug}`;
---

<BaseLayout
  title="abdemon · Selected Projects"
  description="Selected software projects — tooling, automation, and developer productivity work."
>
  <div class="wrap">
    <header class="hero">
      <div class="eyebrow">Works · Index</div>
      <h1><em>Selected</em><br />Projects</h1>
      <p class="lede">
        A small set of things I've designed and built — internal tooling, automation, and developer
        productivity work, written up end to end.
      </p>
    </header>

    <section class="catalog">
      {
        projects.map((p) => (
          <a class="catalog-card" href={workHref(p.id)}>
            {p.data.cover ? (
              <Image
                class="catalog-cover"
                src={p.data.cover}
                alt={p.data.coverAlt ?? p.data.title}
                widths={[480, 800]}
                sizes="(min-width: 760px) 320px, 100vw"
              />
            ) : (
              <div class="catalog-cover catalog-cover--empty" aria-hidden="true" />
            )}
            <div class="catalog-meta">
              <div class="catalog-eyebrow">{p.data.theme}</div>
              <div class="catalog-title">{p.data.title}</div>
              <div class="catalog-lede">{p.data.tagline}</div>
            </div>
          </a>
        ))
      }
    </section>

    <footer>
      <span>Works · Index</span>
      <span>{projects.length} {projects.length === 1 ? 'project' : 'projects'}</span>
      <span>End of file</span>
    </footer>
  </div>
</BaseLayout>

<style>
  .catalog {
    padding: 60px 0 80px;
    border-top: 1px solid var(--rule);
    display: grid;
    gap: 1px;
    background: var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .catalog-card {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 28px;
    background: var(--bg);
    padding: 24px;
    text-decoration: none;
    color: var(--ink);
    transition: background 200ms;
  }
  .catalog-card:hover {
    background: var(--bg-2);
  }
  .catalog-cover {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border: 1px solid var(--rule);
  }
  .catalog-cover--empty {
    background: #14120f;
  }
  .catalog-meta {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 4px;
  }
  .catalog-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--teal);
  }
  .catalog-title {
    font-family: var(--serif);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(26px, 3vw, 36px);
    line-height: 1.05;
    color: var(--ink);
  }
  .catalog-lede {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink-dim);
    max-width: 56ch;
  }
  @media (max-width: 760px) {
    .catalog-card {
      grid-template-columns: 1fr;
      gap: 18px;
    }
    .catalog-cover {
      max-width: 100%;
    }
  }
</style>
