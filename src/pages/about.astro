---
import BaseLayout from "../layouts/BaseLayout.astro";

// TODO(author): replace bio copy, focus items, and the LinkedIn URL below.
const links = [
  { label: "GitHub", href: "https://github.com/AbandonedDemon" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/hiephx574" },
];

const focus = [
  "Internal tooling & workflow automation",
  "Developer productivity & browser extensions",
  "Long-form GFX editing & color work",
];
---

<BaseLayout title="About · abdemon" description="Who I am and what I work on.">
  <div class="wrap">
    <header class="hero">
      <div class="eyebrow">About · abdemon</div>
      <h1><em>About</em></h1>
    </header>

    <section class="about">
      <div class="about-main">
        <p>
          I'm a developer who builds tools that take the friction out of
          repetitive work — grading pipelines, time-logging dashboards,
          publishing flows — and, on the side, write up the GFX editing recipes
          I use myself.
        </p>
        <p>
          Most of what I make starts as a chore I got tired of doing by hand.
          The projects in the
          <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/works`}
            >Works</a
          > section are the ones that outgrew that and became real software.
        </p>

        <h2 class="about-label">What I do</h2>
        <ul class="focus">
          {focus.map((f) => <li>{f}</li>)}
        </ul>
      </div>

      <aside class="about-links">
        <h2 class="about-label">Elsewhere</h2>
        <ul>
          {
            links.map((l) => (
              <li>
                <a href={l.href} target="_blank" rel="noopener noreferrer">
                  {l.label} <span class="arrow">→</span>
                </a>
              </li>
            ))
          }
        </ul>
      </aside>
    </section>

    <footer>
      <span>About · abdemon</span>
      <span>End of file</span>
    </footer>
  </div>
</BaseLayout>

<style>
  .about {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 56px;
    padding: 60px 0 80px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .about-main p {
    font-size: clamp(15.5px, 1.6vw, 18px);
    line-height: 1.7;
    color: var(--ink-dim);
    max-width: 62ch;
    margin-bottom: 16px;
  }
  .about-main p strong {
    color: var(--ink);
    font-weight: 400;
  }
  .about-main a {
    color: var(--teal);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
  }
  .about-main a:hover {
    color: var(--amber);
  }

  .about-label {
    font-family: var(--mono);
    font-weight: 400;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--amber);
    margin: 44px 0 18px;
  }

  .focus {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 62ch;
  }
  .focus li {
    position: relative;
    padding: 12px 0 12px 22px;
    border-bottom: 1px solid var(--rule);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-dim);
  }
  .focus li:last-child {
    border-bottom: 0;
  }
  .focus li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--teal);
    font-family: var(--mono);
  }

  .about-links .about-label {
    margin-top: 0;
  }
  .about-links ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .about-links li {
    border-bottom: 1px solid var(--rule);
  }
  .about-links a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal);
    text-decoration: none;
    transition: color 0.18s ease;
  }
  .about-links a:hover {
    color: var(--amber);
  }
  .about-links .arrow {
    color: var(--ink-faint);
  }
  .about-links a:hover .arrow {
    color: var(--amber);
  }

  @media (max-width: 760px) {
    .about {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
